# ─── Site ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://hubypaa.org
NEXT_PUBLIC_ENABLE_VERCEL_TOOLBAR=0

# ─── HUBYPAA comms module ──────────────────────────────────────────────

# Session signing secret. Min 16 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
HUB_SESSION_SECRET=change-me-please-at-least-sixteen-chars

# Google OAuth credentials (https://console.cloud.google.com/apis/credentials).
# Authorized redirect URI in Google console must be:
#   https://YOUR_DOMAIN/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: override the redirect URI when running behind a proxy.
# HUB_OAUTH_REDIRECT_URL=https://hubypaa.org/auth/callback

# Comma-separated list of Google account emails granted super_admin +
# portal + submitter access on sign-in. Ideal for the first admin(s).
HUB_BOOTSTRAP_ADMIN_EMAILS=

# Optional: override where the file-backed data store lives.
# Defaults to `./.hub-data`. In production on a persistent FS (e.g. a
# mounted Vercel Blob volume, EFS, or a local VM), point this at a
# writable directory. On ephemeral runtimes, swap the store layer for a
# DB adapter — see src/lib/hub/store.ts.
# HUB_DATA_DIR=/var/data/hub